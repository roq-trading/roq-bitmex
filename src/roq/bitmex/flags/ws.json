{
  "name": "WS",
  "type": "flags",
  "prefix": "ws_",
  "values": [
    {
      "name": "uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "wss://ws.testnet.bitmex.com/realtime",
      "description": "WebSocket end-point (URI)"
    },
    {
      "name": "ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "15s",
      "description": "request time-out"
    },
    {
      "name": "cancel_on_disconnect",
      "type": "bool",
      "default": true,
      "description": "cancel orders on disconnect? (bool)"
    },
    {
      "name": "cancel_all_after",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "15s",
      "description": "cancel all after, requires cancel-on-disconnect"
    }
  ]
}
